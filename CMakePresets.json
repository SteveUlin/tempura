{
  "version": 6,
  "configurePresets": [
    {
      "name": "gcc-trunk",
      "displayName": "GCC Trunk (C++26 Reflection)",
      "description": "Build with GCC trunk and -freflection (P2996)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-gcc-trunk",
      "toolchainFile": "${sourceDir}/cmake/toolchains/gcc-trunk.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "TEMPURA_PROFILE_COMPILE": "ON",
        "TEMPURA_BUILD_EXAMPLES": "ON",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "gcc-trunk",
      "configurePreset": "gcc-trunk"
    }
  ],
  "testPresets": [
    {
      "name": "gcc-trunk",
      "configurePreset": "gcc-trunk",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
